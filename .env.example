DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=quadrailearn
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5433
DB_CONNECT_TIMEOUT=5
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_BASE_URL=http://127.0.0.1:5173
MOBILE_APP_BASE_URL=quadrailearn://
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=support@quadravise.com
EMAIL_HOST_PASSWORD=replace-with-your-google-app-password
DEFAULT_FROM_EMAIL=support@quadravise.com
GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
